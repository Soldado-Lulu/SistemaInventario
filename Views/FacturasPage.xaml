<Page x:Class="SistemaInventario.Views.FacturasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource BgAppBrush}"
      Title="FacturasPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0"
                    Style="{StaticResource SoftCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Facturación electrónica"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Genera y revisa XML, GZIP y HASH de las ventas registradas."
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource BgAppBrush}"
                            CornerRadius="16"
                            Padding="14"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Buscar venta"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="TxtBuscarVenta"
                                     Margin="0,8,0,0"
                                     Height="34"
                                     FontSize="14"
                                     TextChanged="TxtBuscarVenta_TextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Zona superior -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Ventas -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardSellBrush}"
                        CornerRadius="24"
                        Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="4"
                                          Opacity="0.18"/>
                    </Border.Effect>

                    <Grid>
                        <Border Background="#7FB5BA"
                                CornerRadius="24"
                                Margin="0,0,0,10"/>

                        <Border Background="{StaticResource CardSellBrush}"
                                CornerRadius="24"
                                Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Ventas registradas"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="Selecciona una venta para generar o revisar su factura."
                                               Margin="0,6,0,0"
                                               Foreground="#F4FFFF"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <DataGrid x:Name="DgVentas"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionChanged="DgVentas_SelectionChanged"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="White"
                                          AlternatingRowBackground="#F2F7F7"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="150"/>
                                        <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="220"/>
                                        <DataGridTextColumn Header="Documento" Binding="{Binding NumeroDocumentoCliente}" Width="140"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="110"/>
                                        <DataGridTextColumn Header="Estado" Binding="{Binding EstadoFiscal}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="4">
                                    <Button x:Name="BtnGenerarFactura"
                                            Content="Generar factura"
                                            Width="160"
                                            Height="40"
                                            Margin="0,0,12,0"
                                            Background="White"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Click="BtnGenerarFactura_Click"/>

                                    <Button x:Name="BtnRecargarVentas"
                                            Content="Recargar"
                                            Width="140"
                                            Height="40"
                                            Background="#EAF7F6"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderThickness="0"
                                            FontWeight="Bold"
                                            Click="BtnRecargarVentas_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Resumen -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Venta seleccionada"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TxtVentaSeleccionada"
                                       Margin="0,10,0,0"
                                       Text="Ninguna"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TxtClienteVenta"
                                       Margin="0,8,0,0"
                                       Text="-"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtTotalVenta"
                                       Margin="0,4,0,0"
                                       Text="-"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Factura"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtEstadoFactura"
                                       Text="Sin generar"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TxtNumeroFactura"
                                       Margin="0,8,0,0"
                                       Text="-"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtCufFactura"
                                       Margin="0,4,0,0"
                                       Text="-"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Hash SHA256"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtHashFactura"
                                       Text="-"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}">
                        <StackPanel>
                            <TextBlock Text="GZIP Base64"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtGzipPreview"
                                       Text="-"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- XML -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SoftCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Detalle técnico"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="XML fiscal listo para el siguiente paso: envío al SIN por SOAP."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource SoftCardStyle}">
                    <StackPanel>
                        <TextBlock Text="XML generado"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBox x:Name="TxtXmlGenerado"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Height="380"
                                 IsReadOnly="True"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>