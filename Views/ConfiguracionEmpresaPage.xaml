<Page x:Class="SistemaInventario.Views.ConfiguracionEmpresaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource BgAppBrush}"
      Title="ConfiguracionEmpresaPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0"
                    Style="{StaticResource SoftCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Configuración de empresa"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Datos del negocio y parámetros base para facturación."
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource BgAppBrush}"
                            CornerRadius="16"
                            Padding="14"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Estado"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtEstadoConfiguracion"
                                       Margin="0,10,0,0"
                                       Text="Sin guardar"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Formulario -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardSellBrush}"
                    CornerRadius="24"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Datos generales del negocio"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Razón social"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtRazonSocial"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="NIT"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtNit"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="Nombre comercial"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtNombreComercial"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="Dirección"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtDireccion"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Teléfono"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtTelefono"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="Municipio"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtMunicipio"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="Correo"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCorreo"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <CheckBox x:Name="ChkActivo"
                                      Content="Configuración activa"
                                      IsChecked="True"
                                      Foreground="White"
                                      FontWeight="SemiBold"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4"
                               Text="Parámetros de facturación"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Código sistema"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCodigoSistema"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="Token delegado"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtTokenDelegado"
                                     Height="80"
                                     Margin="0,0,0,12"
                                     Padding="10,6"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>

                            <TextBlock Text="CUIS"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCuis"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>

                            <TextBlock Text="CUFD actual"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCufdActual"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Código ambiente"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCodigoAmbiente"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"
                                     Text="1"/>

                            <TextBlock Text="Código modalidad"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCodigoModalidad"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"
                                     Text="1"/>

                            <TextBlock Text="Código sucursal"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCodigoSucursal"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"
                                     Text="0"/>

                            <TextBlock Text="Código punto de venta"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtCodigoPuntoVenta"
                                     Height="36"
                                     Margin="0,0,0,12"
                                     Padding="10,6"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="7"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,22,0,0">
                        <Button x:Name="BtnRecargar"
                                Content="Recargar"
                                Width="140"
                                Height="40"
                                Margin="0,0,10,0"
                                Background="White"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Click="BtnRecargar_Click"/>

                        <Button x:Name="BtnGuardar"
                                Content="Guardar configuración"
                                Width="190"
                                Height="40"
                                Background="#EAF7F6"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>