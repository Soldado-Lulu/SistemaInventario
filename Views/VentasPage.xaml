<Page x:Class="SistemaInventario.Views.VentasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource BgAppBrush}"
      Title="VentasPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0"
                    Style="{StaticResource SoftCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Registrar venta"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Selecciona productos, agrega cantidades y confirma la venta."
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource BgAppBrush}"
                            CornerRadius="16"
                            Padding="14"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total actual"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TxtTotalGeneral"
                                       Margin="0,10,0,0"
                                       Text="Bs 0.00"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Formulario -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Tarjeta principal -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardSellBrush}"
                        CornerRadius="24"
                        Padding="0"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="4"
                                          Opacity="0.18"/>
                    </Border.Effect>

                    <Grid>
                        <Border Background="#7FB5BA"
                                CornerRadius="24"
                                Margin="0,0,0,10"/>

                        <Border Background="{StaticResource CardSellBrush}"
                                CornerRadius="24"
                                Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Agregar producto a la venta"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="Elige un producto, define la cantidad y agrégalo al detalle."
                                               Margin="0,6,0,0"
                                               Foreground="#F4FFFF"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Producto"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <ComboBox x:Name="CbProductos"
                                                  Height="36"
                                                  Margin="0,0,0,14"
                                                  DisplayMemberPath="Nombre"
                                                  SelectedValuePath="Id"
                                                  SelectionChanged="CbProductos_SelectionChanged"/>

                                        <TextBlock Text="Cantidad"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtCantidad"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"
                                                 TextChanged="TxtCantidad_TextChanged"/>

                                        <Button x:Name="BtnAgregar"
                                                Content="Agregar al detalle"
                                                Width="150"
                                                Height="40"
                                                Background="White"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                BorderThickness="0"
                                                FontWeight="Bold"
                                                Click="BtnAgregar_Click"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Precio unitario"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtPrecioUnitario"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"
                                                 IsReadOnly="True"/>

                                        <TextBlock Text="Stock disponible"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtStockDisponible"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"
                                                 IsReadOnly="True"/>

                                        <TextBlock Text="Subtotal"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtSubtotal"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"
                                                 IsReadOnly="True"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Resumen -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Resumen"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Confirma el detalle antes de guardar la venta."
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Productos en la venta"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtCantidadItems"
                                       Text="0 ítems"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Total a cobrar"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtTotalResumen"
                                       Text="Bs 0.00"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1F5F5B"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnGuardarVenta"
                            Content="Guardar venta"
                            Height="42"
                            Background="{StaticResource CardSellBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            FontWeight="Bold"
                            Click="BtnGuardarVenta_Click"/>

                    <Button x:Name="BtnQuitarSeleccionado"
                            Content="Quitar seleccionado"
                            Height="42"
                            Margin="0,10,0,0"
                            Background="#FBE4D8"
                            Foreground="#8A3B12"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Click="BtnQuitarSeleccionado_Click"/>

                    <Button x:Name="BtnLimpiarVenta"
                            Content="Limpiar venta"
                            Height="42"
                            Margin="0,10,0,0"
                            Background="#FFF7ED"
                            Foreground="#6B4E2E"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Click="BtnLimpiarVenta_Click"/>
                </StackPanel>
            </Grid>

            <!-- Detalle -->
            <Border Grid.Row="4"
                    Style="{StaticResource SoftCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Detalle de la venta"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Productos agregados a la venta actual."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <DataGrid x:Name="DgDetalleVenta"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              AlternatingRowBackground="#F2F7F7"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Producto.Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="120"/>
                            <DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario}" Width="140"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>