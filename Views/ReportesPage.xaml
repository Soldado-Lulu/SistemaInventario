<Page x:Class="SistemaInventario.Views.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      Background="{StaticResource BgAppBrush}"
      Title="ReportesPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILTRO -->
            <Border Grid.Row="0"
                    Style="{StaticResource SoftCardStyle}"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Reportes"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <DatePicker x:Name="DpFechaInicio"
                                Grid.Column="1"
                                Margin="8,0"/>

                    <DatePicker x:Name="DpFechaFin"
                                Grid.Column="2"
                                Margin="8,0"/>

                    <Button Grid.Column="3"
                            Margin="8,0"
                            Content="Filtrar"
                            Click="BtnFiltrar_Click"/>

                    <Button Grid.Column="4"
                            Margin="8,0"
                            Content="Hoy"
                            Click="BtnHoy_Click"/>

                    <Button x:Name="BtnMostrarGraficas"
                            Grid.Column="5"
                            Margin="8,0"
                            Content="Mostrar gráficas"
                            Click="BtnMostrarGraficas_Click"/>
                </Grid>
            </Border>

            <!-- RESUMEN -->
            <UniformGrid Grid.Row="2" Columns="3">
                <Border Margin="6" Style="{StaticResource SoftCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Total vendido"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtTotalVendido"
                                   Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="Bs 0"/>
                    </StackPanel>
                </Border>

                <Border Margin="6" Style="{StaticResource SoftCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Cantidad ventas"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtCantidadVentas"
                                   Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="0"/>
                    </StackPanel>
                </Border>

                <Border Margin="6" Style="{StaticResource SoftCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Stock bajo"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtStockBajoResumen"
                                   Margin="0,8,0,0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Text="0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- GRAFICAS -->
            <Grid x:Name="PanelGraficas"
                  Grid.Row="4"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="280"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Distribución de ventas"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Participación por producto vendido."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <oxy:PlotView x:Name="PlotVentasPastel"
                                      Grid.Row="2"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="280"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Productos más vendidos"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Cantidad vendida por producto."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <oxy:PlotView x:Name="PlotProductosBarras"
                                      Grid.Row="2"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- TABLAS -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Ventas registradas"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Historial dentro del rango seleccionado."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <DataGrid x:Name="DgVentas"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F2F7F7"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="170"/>
                                <DataGridTextColumn Header="Producto(s)" Binding="{Binding ProductosTexto}" Width="*"/>
                                <DataGridTextColumn Header="Ítems" Binding="{Binding CantidadItems}" Width="80"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Productos con stock bajo"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Productos con 5 unidades o menos."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <DataGrid x:Name="DgStockBajo"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F2F7F7"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria.Nombre}" Width="130"/>
                                <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>