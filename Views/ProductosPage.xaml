<Page x:Class="SistemaInventario.Views.ProductosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource BgAppBrush}"
      Title="ProductosPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource SoftCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Gestión de productos"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Crea, edita y administra tu catálogo de productos."
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource BgAppBrush}"
                            CornerRadius="16"
                            Padding="14"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Buscar producto"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="TxtBuscar"
                                     Margin="0,8,0,0"
                                     Height="34"
                                     FontSize="14"
                                     TextChanged="TxtBuscar_TextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource CardProductsBrush}"
                        CornerRadius="24"
                        Padding="0"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="4"
                                          Opacity="0.18"/>
                    </Border.Effect>

                    <Grid>
                        <Border Background="#D3A26B"
                                CornerRadius="24"
                                Margin="0,0,0,10"/>

                        <Border Background="{StaticResource CardProductsBrush}"
                                CornerRadius="24"
                                Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Agregar producto"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="Completa los datos comerciales y fiscales del producto."
                                               Margin="0,6,0,0"
                                               Foreground="#FFF7ED"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nombre"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtNombre"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Precio compra"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtPrecioCompra"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Precio venta"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtPrecioVenta"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Stock"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtStock"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Categoría"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <ComboBox x:Name="CbCategoria"
                                                  Height="36"
                                                  Margin="0,0,0,14"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  DisplayMemberPath="Nombre"
                                                  SelectedValuePath="Id"
                                                  Padding="8,4"/>

                                        <TextBlock Text="Descripción"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtDescripcion"
                                                 Height="86"
                                                 Margin="0,0,0,14"
                                                 Padding="10,8"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Código actividad económica"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtCodigoActividad"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Código producto SIN"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtCodigoProductoSin"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <TextBlock Text="Unidad medida SIN"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="TxtUnidadMedidaSin"
                                                 Height="36"
                                                 Margin="0,0,0,14"
                                                 Padding="10,6"/>

                                        <CheckBox x:Name="ChkEsServicio"
                                                  Content="Es servicio"
                                                  Margin="0,4,0,10"
                                                  Foreground="White"
                                                  FontWeight="SemiBold"/>

                                        <CheckBox x:Name="ChkTieneVencimiento"
                                                  Content="Tiene fecha de vencimiento"
                                                  Margin="0,0,0,18"
                                                  Foreground="White"
                                                  FontWeight="SemiBold"/>

                                        <WrapPanel>
                                            <Button x:Name="BtnGuardar"
                                                    Content="Guardar"
                                                    Width="105"
                                                    Height="38"
                                                    Margin="0,0,10,10"
                                                    Background="#F5F7F8"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    BorderThickness="0"
                                                    FontWeight="Bold"
                                                    Click="BtnGuardar_Click"/>

                                            <Button x:Name="BtnActualizar"
                                                    Content="Actualizar"
                                                    Width="105"
                                                    Height="38"
                                                    Margin="0,0,10,10"
                                                    Background="#EAF3F3"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    BorderThickness="0"
                                                    FontWeight="Bold"
                                                    Click="BtnActualizar_Click"/>

                                            <Button x:Name="BtnEliminar"
                                                    Content="Eliminar"
                                                    Width="105"
                                                    Height="38"
                                                    Margin="0,0,10,10"
                                                    Background="#FBE4D8"
                                                    Foreground="#8A3B12"
                                                    BorderThickness="0"
                                                    FontWeight="Bold"
                                                    Click="BtnEliminar_Click"/>

                                            <Button x:Name="BtnLimpiar"
                                                    Content="Limpiar"
                                                    Width="105"
                                                    Height="38"
                                                    Margin="0,0,10,10"
                                                    Background="#FFF7ED"
                                                    Foreground="#6B4E2E"
                                                    BorderThickness="0"
                                                    FontWeight="Bold"
                                                    Click="BtnLimpiar_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Resumen"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Incluye datos comerciales y homologación fiscal del producto."
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Catálogo"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtTotalProductos"
                                       Text="0 productos"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Stock bajo"
                                       Foreground="#8B6A46"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtStockBajo"
                                       Text="0 productos"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#7A4E22"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Categorías"
                                       Foreground="#5D7B64"
                                       FontSize="12"/>
                            <TextBlock x:Name="TxtTotalCategorias"
                                       Text="0 categorías"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#3E5B45"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="4"
                    Style="{StaticResource SoftCardStyle}">
                <DataGrid x:Name="DgProductos"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="DgProductos_SelectionChanged"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowBackground="White"
                          AlternatingRowBackground="#F2F7F7"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="180"/>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria.Nombre}" Width="130"/>
                        <DataGridTextColumn Header="Precio Compra" Binding="{Binding PrecioCompra}" Width="110"/>
                        <DataGridTextColumn Header="Precio Venta" Binding="{Binding PrecioVenta}" Width="110"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="80"/>
                        <DataGridTextColumn Header="Actividad" Binding="{Binding CodigoActividadEconomica}" Width="120"/>
                        <DataGridTextColumn Header="Código SIN" Binding="{Binding CodigoProductoSin}" Width="120"/>
                        <DataGridTextColumn Header="Unidad SIN" Binding="{Binding UnidadMedidaSin}" Width="90"/>
                        <DataGridCheckBoxColumn Header="Servicio" Binding="{Binding EsServicio}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Vencimiento" Binding="{Binding TieneFechaVencimiento}" Width="100"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>