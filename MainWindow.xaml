<Window x:Class="SistemaInventario.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema Inventario"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgAppBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SoftCardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="64"
                                Height="64"
                                CornerRadius="32"
                                Background="{StaticResource BgAppBrush}"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1">
                            <Viewbox>
                                <TextBlock Text="🏪"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Viewbox>
                        </Border>

                        <TextBlock Text="TU NEGOCIO"
                                   Margin="0,14,0,6"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Sistema local de inventario"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <Button Content="Inicio"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Dashboard_Click"/>

                    <Button Content="Vender"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Ventas_Click"/>

                    <Button Content="Productos"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Productos_Click"/>

                    <Button Content="Reportes"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Reportes_Click"/>
                    <Button Content="Inventario"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="Inventario_Click"/>
                </StackPanel>

                <Button Grid.Row="4"
                        Content="Salir"
                        Style="{StaticResource SidebarDangerButtonStyle}"
                        Click="Salir_Click"/>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="AUTO"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Background="{StaticResource HeaderBrush}"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="El sistema de gestion de mi negocio"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sistema administrativo de escritorio"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource BgAppBrush}"
                            CornerRadius="18"
                            Padding="16"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Negocio"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="TU NEGOCIO"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>